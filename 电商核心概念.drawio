<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/28.0.4 Chrome/138.0.7204.97 Electron/37.2.1 Safari/537.36" version="28.0.4">
  <diagram id="uXeNC74u_I4rcOdnHXsA" name="电商核心概念">
    <mxGraphModel dx="3911" dy="563" grid="1" gridSize="10" guides="0" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="4681" pageHeight="3300" background="none" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="6AI_76blrhWS6l91PNTs-2" value="电商核心概述说明" style="rounded=1;whiteSpace=wrap;html=1;arcSize=2;verticalAlign=top;fontSize=16;fontStyle=1;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="-1200" y="710" width="390" height="410" as="geometry" />
        </mxCell>
        <mxCell id="6AI_76blrhWS6l91PNTs-8" value="&lt;span style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;SKU（Stock Keeping Unit，库存单位）&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;strong data-end=&quot;7&quot; data-start=&quot;0&quot;&gt;SKU&lt;/strong&gt;是用来标识具体商品变种（如颜色、尺寸、型号等）的唯一编号，每个SKU对应一个具体的商品版本，通常用于库存管理、定价和销售。&lt;span style=&quot;text-align: left;&quot;&gt;&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=7;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="-1190" y="850" width="370" height="90" as="geometry" />
        </mxCell>
        <mxCell id="6AI_76blrhWS6l91PNTs-9" value="&lt;div&gt;&lt;span style=&quot;text-align: left;&quot; data-end=&quot;83&quot; data-start=&quot;76&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;&lt;span style=&quot;&quot; data-end=&quot;47&quot; data-start=&quot;40&quot;&gt;SPU&lt;/span&gt;（Standard Product Unit，标准产品单元）&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;span style=&quot;text-align: left;&quot; data-end=&quot;83&quot; data-start=&quot;76&quot;&gt;&lt;div&gt;&lt;strong style=&quot;text-align: left;&quot; data-end=&quot;83&quot; data-start=&quot;76&quot;&gt;&lt;br&gt;&lt;/strong&gt;&lt;/div&gt;&lt;b&gt;SPU&lt;/b&gt;&lt;/span&gt;&lt;span style=&quot;text-align: left;&quot;&gt;是描述一类相似商品的标准化单元，它代表具有相同核心特征的商品集合，而不涉及具体的颜色、尺寸等差异。一个SPU下可以包含多个SKU。&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=7;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="-1190" y="750" width="370" height="90" as="geometry" />
        </mxCell>
        <mxCell id="6AI_76blrhWS6l91PNTs-18" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="6AI_76blrhWS6l91PNTs-10" target="6AI_76blrhWS6l91PNTs-14" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="6AI_76blrhWS6l91PNTs-10" value="&lt;div&gt;&lt;span style=&quot;text-align: left;&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;平台属性&lt;/font&gt;&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;由电商平台根据商品的类别和用户需求设定的标准化属性，用于帮助用户筛选商品。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
          <mxGeometry x="-1190" y="950" width="370" height="80" as="geometry" />
        </mxCell>
        <mxCell id="6AI_76blrhWS6l91PNTs-19" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="6AI_76blrhWS6l91PNTs-11" target="6AI_76blrhWS6l91PNTs-15" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="6AI_76blrhWS6l91PNTs-11" value="&lt;div&gt;&lt;span style=&quot;text-align: left;&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;销售属性&lt;/font&gt;&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;商家在上传商品时设置的、用户在购买过程中需要选择的属性。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="-1190" y="1040" width="370" height="70" as="geometry" />
        </mxCell>
        <mxCell id="6AI_76blrhWS6l91PNTs-14" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;labelBorderColor=default;imageBackground=none;imageBorder=default;" parent="1" vertex="1">
          <mxGeometry x="-2510" y="875" width="1204.28" height="230" as="geometry" />
        </mxCell>
        <mxCell id="6AI_76blrhWS6l91PNTs-15" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;imageBorder=default;" parent="1" vertex="1">
          <mxGeometry x="-730" y="965" width="608" height="221" as="geometry" />
        </mxCell>
        <mxCell id="6AI_76blrhWS6l91PNTs-16" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;imageBorder=default;" parent="1" vertex="1">
          <mxGeometry x="-1350" y="150" width="709.75" height="490" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
